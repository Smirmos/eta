{
  "name": "@eta/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch --import @swc-node/register/esm-register src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "generate:test-plan": "node --import @swc-node/register/esm-register scripts/generate-test-plan.ts",
    "generate:test-week": "node --import @swc-node/register/esm-register scripts/generate-test-week.ts",
    "render:plan": "node --import @swc-node/register/esm-register scripts/render-plan.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@eta/shared-types": "workspace:*",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/platform-fastify": "^10.4.7",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.28.1",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@swc-node/register": "^1.10.9",
    "@swc/core": "^1.9.3",
    "@swc/helpers": "^0.5.13",
    "@testcontainers/postgresql": "^10.13.2",
    "@types/node": "^20.17.6",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1",
    "testcontainers": "^10.13.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
