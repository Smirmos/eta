# Node environment: development | production | test
NODE_ENV=development

# API listen port
PORT=3000

# Postgres credentials (consumed by docker-compose AND apps/api)
POSTGRES_DB=eta_dev
POSTGRES_USER=eta
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Connection string for apps/api (Drizzle/postgres-js)
# Must match the POSTGRES_* values above when using docker-compose
DATABASE_URL=postgres://eta:change_me@localhost:5432/eta_dev
